<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- M4-1 widget / M4-2 predictive back / M4-3 数据迁移 已落地。

         M4-3 数据迁移:API 30+ Android 11+ 走 SAF(无权限需要);API 26-29 旧设备(Android 8-10)
         用 maxSdkVersion=29 兜底声明 READ/WRITE_EXTERNAL_STORAGE,
         spec §"Android 11+ SAF 路径无需 WRITE_EXTERNAL_STORAGE" + "API 26-29 旧设备 fallback"。 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- morning-freewrite · Android 13+ 通知权限。
         SDK 33+ 才需要;用户拒绝时仍能写但通知不弹。 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- morning-freewrite · 设备开机 / APK 自更新后重排闹钟。
         不申请 SCHEDULE_EXACT_ALARM(Google Play 政策:仅「日历/闹钟/提醒」
         类目可申请,本应用不属于 — 用 setAndAllowWhileIdle 做 fallback)。 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".app.WritingApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.WritingApp"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".app.MainActivity"
            android:enableOnBackInvokedCallback="true"
            android:exported="true"
            android:theme="@style/Theme.WritingApp"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="locale|layoutDirection|orientation|screenSize|smallestScreenSize|screenLayout">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- M4-1 · 桌面小组件 receiver(widget "随手记")-->
        <receiver
            android:name=".core.widget.QuickNoteWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_2x2_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- M5 widget-1x4-compact · 1x4 compact widget receiver(独立 cell-size hint) -->
        <receiver
            android:name=".core.widget.QuickNote1x4WidgetReceiver"
            android:exported="false"
            android:label="@string/widget_1x4_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_1x4" />
        </receiver>
            <!-- 1x1 快速记笔记 widget receiver -->
        <receiver
            android:name=".core.widget.QuickNote1x1WidgetReceiver"
            android:exported="false"
            android:label="@string/widget_1x1_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_1x1" />
        </receiver>

        <!-- feishu-user-oauth · 回调接收 Activity。
             OAuthLauncher.REDIRECT_URI 与此处的 scheme/host/path 必须一致。
             ux-2026-06-29 r2:不用 taskAffinity="" 隔离 task。原因:独立 task 时
             receiver finish 后系统回退到 intent source(浏览器 task),startMainActivity
             创建的 MainActivity task 反而不是"front"task，用户被丢回浏览器。
             改用默认 affinity → receiver 跟 MainActivity 共享同一 task → receiver
             finish 时 MainActivity 在同 task back stack 下方自动顶上，用户留在 app。
             re-delivery(手动开 app 触发原始 intent 重投)由 OAuthCodeReceiver.onCreate
             内的 hasPendingExchange 幂等检查兜底，不依赖 task 隔离。 -->
        <activity
            android:name=".core.feishu.auth.OAuthCodeReceiver"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.WritingApp.Translucent">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="com.yy.writingwithai"
                    android:host="feishu"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <!-- app-self-hosted-update · APK 下载完成 broadcast 接收。
             DownloadManager enqueue 完一个下载任务后会发 ACTION_DOWNLOAD_COMPLETE,
             receiver 拿到对应 APK 文件 + SHA-256 校验 + 触发系统安装 intent。
             exported=false:API 26+ 系统 broadcast 可送达，无外暴露面。 -->
        <receiver
            android:name=".core.update.UpdateDownloadReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- morning-freewrite · 开机 / APK 更新后重排闹钟(design §3.3)。
             BOOT_COMPLETED 必须是 exported=true 才能接收系统级 broadcast;
             MY_PACKAGE_REPLACED 是同包 update(Android 不限制 exported,这里 true 保险)。 -->
        <receiver
            android:name=".core.notification.MorningFreewriteBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- morning-freewrite · 闹钟触发接收器(AlarmManager → 通知)。
             不需要 exported(系统自起广播),exported=false 即可。 -->
        <receiver
            android:name=".core.notification.MorningFreewriteAlarmReceiver"
            android:exported="false" />

        <!-- app-self-hosted-update · FileProvider，把 App-private external 下载目录
             暴露成 content:// URI 给系统安装器，避开 API 24+ 的 FileUriExposedException。 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- app-self-hosted-update · targetSdk 30+ 包可见性:声明调用安装器 intent。
         否则 ACTION_VIEW + application/vnd.android.package-archive 解析不到安装器。 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.INSTALL_PACKAGE" />
        </intent>

        <!-- 飞书 OAuth · targetSdk 30+ 包可见性:声明 ACTION_VIEW + http/https intent,
             否则 CustomTabsIntent.launchUrl 与 ACTION_VIEW fallback 解析不到任何浏览器 →
             ActivityNotFoundException → 误报「未找到可用的浏览器」(跟设备有没有自带浏览器
             无关，Android 11+ 默认屏蔽未声明的 intent visibility)。
             Custom Tabs service 声明供 androidx.browser 在选默认 chrome custom tab provider
             时用，不在 <queries> 时同样解析不到。 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

</manifest>