<?xml version="1.0" encoding="utf-8"?>
<!-- 小札 launcher icon foreground — 落笔瞬间 + 末端墨点。
     108dp viewport + 18dp safe zone → glyph 落在 18~90 区间。
     笔触 8dp 圆头,斜下从左上 (28,30) 到右下 (78,72);末端散 4 颗墨点。 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 主笔触:从左上向右下落笔,粗墨痕 -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M30,32 L78,72" />

    <!-- 末端墨点:由大到小向右下角散开,呈"墨溅"感 -->
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M82,76 m-3.2,0 a3.2,3.2 0 1,0 6.4,0 a3.2,3.2 0 1,0 -6.4,0" />
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M88,82 m-2.1,0 a2.1,2.1 0 1,0 4.2,0 a2.1,2.1 0 1,0 -4.2,0" />
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M74,84 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0" />
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M66,86 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0" />

</vector>