<?xml version="1.0" encoding="utf-8"?>
<!-- 小札 launcher icon v2 — 信笺折角 + 笔痕 + 札字
     108dp viewport + 18dp safe zone → glyph 落在 18~90 区间。
     纸页: 32~76 h × 22~82 v,右上角折角,纸面中央一道斜笔痕,
     纸面下方"札"字三笔(撇+横+竖)。 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 折角阴影(右上角三角形,墨色,先画在最底层让纸页覆盖一部分) -->
    <path
        android:fillColor="#D9CFBE"
        android:pathData="M76,22 L66,22 L76,32 Z" />

    <!-- 纸页主体:圆角矩形(纸白色) -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="2.5"
        android:strokeLineJoin="round"
        android:pathData="M34,22 L66,22 L76,32 L76,82 Q76,84 74,84 L34,84 Q32,84 32,82 L32,24 Q32,22 34,22 Z" />

    <!-- 折角折线(墨色,描出折痕) -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M66,22 L66,32 L76,32" />

    <!-- 纸面中央斜笔痕(墨色,暗示书写) -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M40,46 L68,58" />

    <!-- "札"字三笔:撇 + 横 + 竖,中央偏下 -->
    <!-- 撇:从左上到右下 -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:pathData="M48,66 L58,78" />
    <!-- 横:从上到下中部 -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:pathData="M50,72 L66,72" />
    <!-- 竖:穿过横 -->
    <path
        android:fillColor="#1A1A1A"
        android:strokeColor="#1A1A1A"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:pathData="M60,66 L60,78" />

</vector>